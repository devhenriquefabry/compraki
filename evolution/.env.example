# Copy this file to evolution/.env for local Docker usage.
# Never commit real credentials.

SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=http://localhost:8080

# Required by Evolution API. Generate a long random value.
AUTHENTICATION_API_KEY=replace_with_long_random_api_key
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=false

# Neon Postgres
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require
DATABASE_CONNECTION_CLIENT_NAME=compraki_evolution
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true

# Upstash Redis
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=rediss://default:PASSWORD@HOST.upstash.io:PORT
CACHE_REDIS_PREFIX_KEY=compraki_evolution
CACHE_REDIS_SAVE_INSTANCES=true

# Global webhook to Firebase Functions
WEBHOOK_GLOBAL_ENABLED=true
WEBHOOK_GLOBAL_URL=https://REGION-PROJECT_ID.cloudfunctions.net/evolutionWebhook
WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=true
WEBHOOK_EVENTS_APPLICATION_STARTUP=false
WEBHOOK_EVENTS_QRCODE_UPDATED=true
WEBHOOK_EVENTS_CONNECTION_UPDATE=true
WEBHOOK_EVENTS_MESSAGES_UPSERT=true
WEBHOOK_EVENTS_MESSAGES_UPDATE=true
WEBHOOK_EVENTS_SEND_MESSAGE=true
WEBHOOK_REQUEST_TIMEOUT_MS=60000

# QR Code and session behavior
QRCODE_LIMIT=30
QRCODE_COLOR=#4a9c2b

# Optional integrations kept disabled by default
RABBITMQ_ENABLED=false
SQS_ENABLED=false
WEBSOCKET_ENABLED=false
