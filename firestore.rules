rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.super_admin == true ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          )
        )
      );
    }

    // Cache global de mídias do WhatsApp: leitura para admins, escrita apenas via Cloud Functions (Admin SDK).
    match /whatsappMediaCache/{mediaId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Estatísticas agregadas do cache (hits/misses/bytesStored).
    match /whatsappMediaCacheStats/{statsDoc} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
