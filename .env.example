# ============================================================
# COMPRAKI — Variáveis de Ambiente (raiz do projeto)
# ============================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env com dados reais!
#
#   cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# BOT DE AUTOMAÇÃO (bot-server.js)
# ----------------------------------------------------------

# Chave da API do Groq (para geração de texto com IA)
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=

# Alternativa: chave da API da xAI (Grok)
# Obtenha em: https://x.ai/api
XAI_API_KEY=

# ----------------------------------------------------------
# SERVIDOR LOCAL
# ----------------------------------------------------------

# Porta do bot-server (padrão: 3001)
BOT_SERVER_PORT=3001
