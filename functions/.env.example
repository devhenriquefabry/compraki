# Copy values into Firebase Functions environment/secrets.
# Do not commit real credentials.

EVOLUTION_API_URL=https://your-evolution-service.example.com
EVOLUTION_API_KEY=replace_with_evolution_authentication_api_key
# Opcional: mesmo segredo usado em Evolution WEBHOOK_GLOBAL (validação no evolutionWebhook)
EVOLUTION_WEBHOOK_SECRET=replace_with_random_webhook_secret
ADMIN_EMAILS=admin@example.com,owner@example.com
ALLOWED_ORIGIN=http://localhost:8100
ALLOWED_ORIGINS=http://localhost:8100,https://your-app.example.com
