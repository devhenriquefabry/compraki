# ============================================================
# COMPRAKI — Variáveis de Ambiente das Cloud Functions
# ============================================================
# Copie este arquivo para functions/.env e preencha com seus valores reais.
# NUNCA commite o arquivo .env com dados reais!
#
#   cp functions/.env.example functions/.env
# ============================================================

# ----------------------------------------------------------
# EVOLUTION API (WhatsApp)
# ----------------------------------------------------------

# URL base da sua instância da Evolution API
# Exemplo: https://sua-instancia.up.railway.app
EVOLUTION_API_URL=

# Chave global de autenticação da Evolution API
# Defina no painel da Evolution API > Global API Key
EVOLUTION_API_KEY=

# Segredo para validação de webhooks da Evolution API (opcional)
EVOLUTION_WEBHOOK_SECRET=

# Origens permitidas para CORS (use * em dev, defina o domínio em produção)
ALLOWED_ORIGIN=*

# ----------------------------------------------------------
# SMTP — Envio de E-mail (recuperação de senha)
# ----------------------------------------------------------

# Host do servidor SMTP
# Gmail: smtp.gmail.com
SMTP_HOST=smtp.gmail.com

# Porta SMTP (587 para TLS, 465 para SSL)
SMTP_PORT=587

# Use "true" para SSL direto (porta 465), "false" para STARTTLS (porta 587)
SMTP_SECURE=false

# E-mail remetente (sua conta Gmail ou outro provedor)
SMTP_USER=

# Senha de app do Gmail (não a senha normal da conta!)
# Gere em: https://myaccount.google.com/apppasswords
SMTP_PASS=

# ----------------------------------------------------------
# ADMIN
# ----------------------------------------------------------

# E-mails com privilégios de administrador (separados por vírgula)
ADMIN_EMAILS=
